# ─── Terraform ────────────────────────────────────────────────────────────────
.terraform/
*.tfstate
*.tfstate.*
*.tfstate.d/
*.tfplan
terraform.tfvars
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
# .terraform.lock.hcl is intentionally tracked (locks provider versions)

# ─── SSH keys (auto-generated by Terraform, never committed) ──────────────────
*.pem
*.key

# ─── Ansible ──────────────────────────────────────────────────────────────────
# Generated inventory from Terraform output (contains live IPs)
**/inventario_terraform.yaml
*.retry

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
.venv/
venv/

# ─── macOS / Editor ───────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# ─── Claude Code ──────────────────────────────────────────────────────────────
.claude/
