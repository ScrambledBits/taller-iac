<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>WebStack · BootcampPeru IaC</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;900&family=Share+Tech+Mono&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg:          #070b12;
      --surface:     #0d1520;
      --card:        #0f1c2a;
      --border:      #1a2d42;
      --cyan:        #00d4ff;
      --green:       #00ff88;
      --amber:       #ffb700;
      --red:         #ff3b5c;
      --text:        #c8d6e8;
      --text-dim:    #4a6080;
      --text-muted:  #1e2d3e;
      --glow-cyan:   0 0 18px rgba(0, 212, 255, 0.35);
      --glow-green:  0 0 18px rgba(0, 255, 136, 0.35);
      --glow-red:    0 0 18px rgba(255, 59, 92, 0.35);
      --glow-amber:  0 0 18px rgba(255, 183, 0, 0.35);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Share Tech Mono', monospace;
      background-color: var(--bg);
      color: var(--text);
      min-height: 100vh;
      overflow-x: hidden;
      background-image:
        linear-gradient(rgba(0, 212, 255, 0.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0, 212, 255, 0.025) 1px, transparent 1px);
      background-size: 44px 44px;
    }

    /* ── Header ─────────────────────────────────────────────────── */

    header {
      border-bottom: 1px solid var(--border);
      padding: 1.25rem 2.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: linear-gradient(180deg, rgba(0, 212, 255, 0.04) 0%, transparent 100%);
    }

    .logo {
      font-family: 'Orbitron', monospace;
      font-size: 1.15rem;
      font-weight: 900;
      color: var(--cyan);
      text-shadow: var(--glow-cyan);
      letter-spacing: 0.12em;
    }
    .logo em {
      font-style: normal;
      color: var(--text-dim);
      font-weight: 400;
    }
    .logo-sub {
      margin-top: 0.2rem;
      font-size: 0.6rem;
      color: var(--text-dim);
      letter-spacing: 0.2em;
    }

    .header-right {
      text-align: right;
      font-size: 0.65rem;
      color: var(--text-dim);
      line-height: 1.9;
    }

    .live-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      background: rgba(0, 255, 136, 0.07);
      border: 1px solid rgba(0, 255, 136, 0.28);
      color: var(--green);
      font-size: 0.6rem;
      padding: 0.18rem 0.55rem;
      letter-spacing: 0.18em;
    }

    .live-dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--green);
      animation: blink 1.6s infinite;
    }

    @keyframes blink {
      0%, 100% { opacity: 1; box-shadow: 0 0 5px var(--green); }
      50%       { opacity: 0.25; box-shadow: none; }
    }

    /* ── Layout ──────────────────────────────────────────────────── */

    main {
      max-width: 1080px;
      margin: 0 auto;
      padding: 2.5rem 2rem 3rem;
    }

    /* ── Topology ────────────────────────────────────────────────── */

    .topology {
      position: relative;
      display: flex;
      align-items: center;
      gap: 0;
      margin-bottom: 2.5rem;
      padding: 2rem 1.5rem 1.5rem;
      border: 1px solid var(--border);
      background: var(--surface);
      overflow: hidden;
    }

    .topology-label {
      position: absolute;
      top: 0.55rem;
      left: 1rem;
      font-size: 0.55rem;
      letter-spacing: 0.25em;
      color: var(--text-muted);
    }

    .topo-node {
      flex: 1;
      padding: 1rem 1.2rem;
      border: 1px solid var(--border);
      background: var(--card);
      text-align: center;
      transition: border-color 0.4s, box-shadow 0.4s;
    }
    .topo-node.self {
      border-color: var(--cyan);
      box-shadow: var(--glow-cyan);
    }

    .topo-node-role {
      font-family: 'Orbitron', monospace;
      font-size: 0.55rem;
      font-weight: 600;
      letter-spacing: 0.22em;
      color: var(--text-dim);
      margin-bottom: 0.4rem;
    }
    .topo-node-tech {
      font-size: 0.9rem;
      color: var(--text);
      margin-bottom: 0.2rem;
    }
    .topo-node-host {
      font-size: 0.62rem;
      color: var(--text-dim);
    }
    .topo-node-port {
      margin-top: 0.3rem;
      font-size: 0.62rem;
    }

    /* ── Animated arrow ──────────────────────────────────────────── */

    .topo-pipe {
      flex: 0 0 100px;
      position: relative;
      height: 2px;
      background: linear-gradient(90deg, var(--cyan), var(--green));
    }
    .topo-pipe::after {
      content: '';
      position: absolute;
      right: -1px; top: 50%;
      transform: translateY(-50%);
      border-left: 7px solid var(--green);
      border-top: 4px solid transparent;
      border-bottom: 4px solid transparent;
    }
    .pipe-label {
      position: absolute;
      top: -16px; left: 50%;
      transform: translateX(-50%);
      font-size: 0.52rem;
      letter-spacing: 0.12em;
      color: var(--text-dim);
      white-space: nowrap;
    }
    .pipe-packet {
      position: absolute;
      top: 50%; left: 0;
      transform: translateY(-50%);
      width: 7px; height: 7px;
      border-radius: 50%;
      background: var(--cyan);
      box-shadow: 0 0 8px var(--cyan);
      animation: pkt-fwd 2.2s linear infinite;
    }
    .pipe-packet.ret {
      background: var(--green);
      box-shadow: 0 0 8px var(--green);
      animation: pkt-ret 2.2s linear infinite 1.1s;
    }
    @keyframes pkt-fwd {
      0%   { left: 0;    opacity: 1; }
      85%  { opacity: 1; }
      100% { left: 100%; opacity: 0; }
    }
    @keyframes pkt-ret {
      0%   { left: 100%; opacity: 1; }
      85%  { opacity: 1; }
      100% { left: 0;    opacity: 0; }
    }

    /* ── Section label ───────────────────────────────────────────── */

    .section-label {
      font-family: 'Orbitron', monospace;
      font-size: 0.58rem;
      font-weight: 600;
      letter-spacing: 0.22em;
      color: var(--text-dim);
      border-left: 2px solid var(--cyan);
      padding-left: 0.6rem;
      margin-bottom: 1rem;
    }

    /* ── Panels grid ─────────────────────────────────────────────── */

    .panels {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      margin-bottom: 1.5rem;
    }
    @media (max-width: 680px) {
      .panels { grid-template-columns: 1fr; }
      .topology { flex-direction: column; gap: 0.8rem; }
      .topo-pipe { flex: 0 0 40px; width: 2px; height: 40px; transform: rotate(90deg); }
    }

    .panel {
      border: 1px solid var(--border);
      background: var(--surface);
    }
    .panel-head {
      padding: 0.65rem 1.1rem;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: rgba(0, 212, 255, 0.025);
    }
    .panel-title {
      font-family: 'Orbitron', monospace;
      font-size: 0.58rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      color: var(--text-dim);
    }
    .panel-badge {
      font-size: 0.58rem;
      color: var(--text-dim);
    }
    .panel-body { padding: 1.4rem 1.1rem; }

    /* ── Status indicator ────────────────────────────────────────── */

    .status-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1.2rem;
    }
    .status-pill {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.72rem;
    }
    .s-dot {
      width: 10px; height: 10px;
      border-radius: 50%;
      background: var(--text-muted);
      transition: background 0.4s, box-shadow 0.4s;
    }
    .s-dot.ok    { background: var(--green); box-shadow: var(--glow-green); animation: pulse-dot 2s infinite; }
    .s-dot.error { background: var(--red);   box-shadow: var(--glow-red); }
    .s-dot.warn  { background: var(--amber); box-shadow: var(--glow-amber); }

    @keyframes pulse-dot {
      0%, 100% { transform: scale(1); }
      50%       { transform: scale(1.35); }
    }

    /* ── Data grid ───────────────────────────────────────────────── */

    .data-grid {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 0.45rem 1rem;
      font-size: 0.68rem;
    }
    .dk { color: var(--text-dim); }
    .dv { color: var(--text); word-break: break-all; }
    .dv.hl  { color: var(--cyan); }
    .dv.ok  { color: var(--green); }
    .dv.err { color: var(--red); }

    /* ── Button ──────────────────────────────────────────────────── */

    .btn {
      font-family: 'Share Tech Mono', monospace;
      font-size: 0.72rem;
      letter-spacing: 0.14em;
      padding: 0.6rem 1.3rem;
      border: 1px solid var(--cyan);
      background: transparent;
      color: var(--cyan);
      cursor: pointer;
      position: relative;
      overflow: hidden;
      transition: color 0.2s;
      width: 100%;
    }
    .btn::before {
      content: '';
      position: absolute;
      inset: 0;
      background: var(--cyan);
      transform: translateX(-101%);
      transition: transform 0.22s ease;
      z-index: 0;
    }
    .btn:hover::before  { transform: translateX(0); }
    .btn:hover          { color: var(--bg); }
    .btn:active         { opacity: 0.75; }
    .btn:disabled       { opacity: 0.45; cursor: not-allowed; }
    .btn > span         { position: relative; z-index: 1; }

    /* ── Response box ────────────────────────────────────────────── */

    .response-box {
      margin-top: 1rem;
      padding: 0.9rem 1rem;
      border: 1px solid var(--border);
      background: var(--card);
      min-height: 80px;
      font-size: 0.68rem;
      line-height: 1.8;
      transition: border-color 0.35s, box-shadow 0.35s;
    }
    .response-box.flash {
      border-color: var(--green);
      box-shadow: 0 0 10px rgba(0, 255, 136, 0.18);
      animation: resp-flash 0.4s ease;
    }
    @keyframes resp-flash {
      0%   { border-color: var(--cyan); }
      100% { border-color: var(--green); }
    }
    .placeholder { color: var(--text-muted); font-size: 0.62rem; }
    .resp-grid {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 0.3rem 0.9rem;
    }
    .resp-grid span:first-child { color: var(--text-dim); }
    .resp-grid span:last-child  { color: var(--green); }

    /* ── Request log ─────────────────────────────────────────────── */

    .log-panel {
      border: 1px solid var(--border);
      background: var(--surface);
    }
    .log-entries {
      padding: 0.5rem 1.1rem 0.75rem;
      max-height: 200px;
      overflow-y: auto;
      scrollbar-width: thin;
      scrollbar-color: var(--border) transparent;
    }
    .log-entry {
      display: grid;
      grid-template-columns: 7rem 3.5rem 5.5rem 1fr;
      gap: 0.5rem;
      font-size: 0.62rem;
      padding: 0.28rem 0;
      border-bottom: 1px solid var(--text-muted);
      animation: log-in 0.25s ease;
    }
    @keyframes log-in {
      from { opacity: 0; transform: translateY(-3px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .log-time   { color: var(--text-dim); }
    .log-method { color: var(--amber); }
    .log-ok     { color: var(--green); }
    .log-err    { color: var(--red); }
    .log-url    { color: var(--text); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .log-empty  { font-size: 0.62rem; color: var(--text-muted); padding: 0.5rem 0; }

    /* ── Footer ──────────────────────────────────────────────────── */

    footer {
      border-top: 1px solid var(--border);
      padding: 0.85rem 2.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-size: 0.58rem;
      color: var(--text-muted);
    }

    /* ── Loading dots ────────────────────────────────────────────── */

    .ldots::after {
      content: '.';
      animation: ldots 1.2s steps(3, end) infinite;
    }
    @keyframes ldots {
      0%   { content: '.';   }
      33%  { content: '..';  }
      66%  { content: '...'; }
      100% { content: '';    }
    }
  </style>
</head>
<body>

  <header>
    <div>
      <div class="logo">WEBSTACK <em>/ BOOTCAMPERU</em></div>
      <div class="logo-sub">INFRAESTRUCTURA COMO CÓDIGO · TALLER IaC</div>
    </div>
    <div class="header-right">
      <div><span class="live-badge"><span class="live-dot"></span>EN VIVO</span></div>
      <div>HOST: <span style="color:var(--text)">{{ inventory_hostname }}</span></div>
      <div id="clock">--:--:--</div>
    </div>
  </header>

  <main>

    <!-- Topology -->
    <div class="topology">
      <span class="topology-label">TOPOLOGÍA DE RED</span>

      <div class="topo-node self">
        <div class="topo-node-role">FRONTEND</div>
        <div class="topo-node-tech">nginx</div>
        <div class="topo-node-host">{{ inventory_hostname }}</div>
        <div class="topo-node-port" style="color:var(--cyan)">:80</div>
      </div>

      <div class="topo-pipe">
        <span class="pipe-label">REVERSE PROXY · /api/*</span>
        <div class="pipe-packet"></div>
        <div class="pipe-packet ret"></div>
      </div>

      <div class="topo-node" id="backend-node">
        <div class="topo-node-role">BACKEND</div>
        <div class="topo-node-tech">Flask</div>
        <div class="topo-node-host" id="backend-host">conectando<span class="ldots"></span></div>
        <div class="topo-node-port" style="color:var(--text-dim)">:5000</div>
      </div>
    </div>

    <!-- Panels -->
    <div class="panels">

      <!-- Health -->
      <div class="panel">
        <div class="panel-head">
          <span class="panel-title">ESTADO DEL BACKEND</span>
          <span class="panel-badge" id="latency-badge"></span>
        </div>
        <div class="panel-body">
          <div class="status-row">
            <div class="status-pill">
              <div class="s-dot" id="s-dot"></div>
              <span id="s-text" style="color:var(--text-dim)">verificando<span class="ldots"></span></span>
            </div>
            <span style="font-size:0.6rem;color:var(--text-dim)" id="next-check"></span>
          </div>
          <div class="data-grid">
            <span class="dk">endpoint</span>  <span class="dv">/api/health</span>
            <span class="dk">status</span>    <span class="dv" id="hd-status">—</span>
            <span class="dk">host</span>      <span class="dv hl" id="hd-host">—</span>
            <span class="dk">deployed_by</span><span class="dv" id="hd-deployed">—</span>
            <span class="dk">timestamp</span> <span class="dv" id="hd-ts">—</span>
          </div>
        </div>
      </div>

      <!-- Hello -->
      <div class="panel">
        <div class="panel-head">
          <span class="panel-title">PRUEBA DE CONECTIVIDAD</span>
          <span class="panel-badge">/api/hello</span>
        </div>
        <div class="panel-body">
          <p style="font-size:0.68rem;color:var(--text-dim);line-height:1.7;margin-bottom:1.1rem">
            Envía una petición HTTP al backend vía proxy inverso nginx para verificar conectividad end-to-end.
          </p>
          <button class="btn" id="hello-btn">
            <span id="hello-btn-label">&#9654; ENVIAR PETICIÓN</span>
          </button>
          <div class="response-box" id="resp-box">
            <span class="placeholder">// la respuesta aparecerá aquí</span>
          </div>
        </div>
      </div>

    </div>

    <!-- Request log -->
    <div class="log-panel">
      <div class="panel-head">
        <span class="panel-title">REGISTRO DE PETICIONES</span>
        <span class="panel-badge" id="req-count">0 peticiones</span>
      </div>
      <div class="log-entries" id="log-entries">
        <div class="log-empty">// sin actividad aún</div>
      </div>
    </div>

  </main>

  <footer>
    <span>WEBSTACK · BOOTCAMPERU · TALLER IaC 2025</span>
    <span>nginx &#8594; Flask · Desplegado con Ansible · {{ inventory_hostname }}</span>
  </footer>

  <script src="api.js"></script>
</body>
</html>
